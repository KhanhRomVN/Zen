{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"label": "npm: compile",
			"detail": "npm run compile"
		},
		{
			"type": "npm",
			"script": "watch",
			"label": "npm: watch",
			"isBackground": true,
			"problemMatcher": {
				"owner": "typescript",
				"fileLocation": ["relative", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"code": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[EXT\\]|^\\[WV\\]",
					"endsPattern": "^.*compiled successfully.*$"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "new",
				"group": "watch"
			}
		}
	]
}
