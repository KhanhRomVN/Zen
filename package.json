{
  "name": "khanhromvn-zen",
  "displayName": "Zen - Free AI Chat For ALL LLM",
  "description": "A powerful VSCode extension that brings AI chat capabilities directly into your development environment",
  "version": "1.5.8",
  "publisher": "KhanhRomVN",
  "license": "MIT",
  "capabilities": {
    "exportedAPI": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KhanhRomVN/Zen"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "free",
    "chat",
    "agent",
    "openai",
    "claude",
    "gemini",
    "ollama",
    "copilot",
    "assistant",
    "multi-llm",
    "free-ai",
    "code-assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zen-container",
          "title": "Zen",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "zen-container": [
        {
          "id": "zen-chat",
          "name": "Chat",
          "type": "webview",
          "contextualTitle": "Zen Chat"
        },
        {
          "id": "zen-accounts",
          "name": "Accounts",
          "type": "webview",
          "contextualTitle": "Zen Accounts"
        }
      ]
    },
    "commands": [
      {
        "command": "zen.openChat",
        "title": "Open Zen Chat",
        "category": "Zen"
      },
      {
        "command": "zen.openAccounts",
        "title": "Open Accounts",
        "category": "Zen",
        "icon": "$(organization)"
      },
      {
        "command": "zen.refreshProjectStructure",
        "title": "Refresh Structure",
        "category": "Zen",
        "icon": "$(refresh)"
      },
      {
        "command": "zen.settings",
        "title": "Open Settings",
        "category": "Zen",
        "icon": "$(gear)"
      },
      {
        "command": "zen.history",
        "title": "View History",
        "category": "Zen",
        "icon": "$(history)"
      },
      {
        "command": "zen.newChat",
        "title": "New Chat",
        "category": "Zen",
        "icon": "$(add)"
      },
      {
        "command": "zen.addToContext",
        "title": "Add to Zen Context",
        "category": "Zen"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "zen.settings",
          "when": "view == zen-chat",
          "group": "navigation",
          "icon": "$(settings)"
        },
        {
          "command": "zen.history",
          "when": "view == zen-chat",
          "group": "navigation",
          "icon": "$(history)"
        },
        {
          "command": "zen.newChat",
          "when": "view == zen-chat",
          "group": "navigation",
          "icon": "$(add)"
        },
        {
          "command": "zen.openAccounts",
          "when": "view == zen-chat",
          "group": "navigation",
          "icon": "$(organization)"
        },
        {
          "command": "zen.refreshProjectStructure",
          "when": "view == zen-project-structure",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "zen.addToContext",
          "group": "zen@1"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "webpack --config webpack.config.js",
    "compile:webview": "cd src/webview-ui && npm install && npm run build && cd ../.. && bash remove-dts-files.sh",
    "watch": "npx concurrently -n \"EXT,WV,DTS\" -c \"blue,green,magenta\" \"npm run watch:extension\" \"npm run watch:webview\" \"bash remove-dts-files.sh watch\"",
    "watch:extension": "webpack --watch --config webpack.config.js",
    "watch:webview": "cd src/webview-ui && npm run watch 2>&1 | node ../../scripts/relpath-log.mjs",
    "package": "npm run package:extension && npm run package:webview",
    "package:extension": "webpack --mode production --devtool hidden-source-map --config webpack.config.js",
    "package:webview": "cd src/webview-ui && npm run build && cd ../.. && bash remove-dts-files.sh",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "unit-test": "mocha out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.41",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.50.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "eslint": "^9.23.0",
    "fast-check": "^4.8.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.2",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.17.0",
    "fuse.js": "^6.6.2",
    "node-pty": "^1.1.0",
    "shiki": "^3.22.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  }
}
